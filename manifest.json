{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "3.4",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "author": "lasdocas",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "*://*.youtube.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.js", "style.css"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
    "commands": {
    "toggle_fullscreen_settings": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "__MSG_commandToggleDesc__"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}